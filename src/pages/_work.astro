---
import Layout from '../layouts/default.astro';
import {
  PageHeader,
  PageHeadingGroup,
  PageLead,
  PageTitle,
  SubsectionHeading,
} from '../design-system/index.js';
import PageIcon from '../icons/PageIcon.jsx';
import Speaking from '../icons/Speaking.jsx';
---
<Layout title="Work">
  <PageHeader>
    <PageIcon Icon={Speaking} />
    <PageHeadingGroup>
      <PageTitle>Current & Past Projects</PageTitle>
      <PageLead>
        Something about developer experience and tools.
      </PageLead>
    </PageHeadingGroup>
  </PageHeader>
  <SubsectionHeading>Developer Tools</SubsectionHeading>
</Layout>
