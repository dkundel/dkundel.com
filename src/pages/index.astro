---
import Layout from '../layouts/default.astro';
import {
  HomeIntro,
  Paragraphs,
  SocialList,
  SubsectionHeading,
  TopicList,
} from '../design-system/index.js';
import data from '../../data/about/dkundel.json';

---
<!-- Below is your "component template." It's just HTML, but with
     some magic sprinkled in to help you build great templates. -->
  <Layout title="About Me">
  <HomeIntro />
  <SubsectionHeading>Biography</SubsectionHeading>
  <Paragraphs list={data.biography._paragraphs} />
  <SubsectionHeading>Examples of previous talks</SubsectionHeading>
  <Paragraphs list={data.biography.examplesOfPreviousTalks._paragraphs}/>
  <TopicList talks={data.biography.examplesOfPreviousTalks._list} />
  <SubsectionHeading>Reach me on:</SubsectionHeading>
  <SocialList channels={data.socialChannels._list} />
  </Layout>
